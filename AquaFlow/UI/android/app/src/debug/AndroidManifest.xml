<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- DEV-ONLY: the AquaFlow backend runs over plain HTTP (http://...:5161),
         and Android blocks cleartext traffic by default. This overlay applies
         ONLY to debug builds, so release builds stay secure. In production the
         backend must be served over HTTPS and this flag must NOT be set.
         See UI/README.md ("Local dev network settings"). -->
    <application android:usesCleartextTraffic="true" />
</manifest>
